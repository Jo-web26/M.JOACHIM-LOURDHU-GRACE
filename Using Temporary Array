#include <stdio.h>

void rev(int arr[], int n) {
    int temp[n];
  
  	// Store elements into temp in reverse order
    for (int i = 0; i < n; i++) {
        temp[i] = arr[n - 1 - i]; 
    }
    
    // Copy reversed array back to original array
    for (int i = 0; i < n; i++) {
        arr[i] = temp[i];
    }
}

int main() {
    int arr[] = {1, 2, 3, 4, 5};
    int n = sizeof(arr) / sizeof(arr[0]);

  	// Reverse the array arr
    rev(arr, n);
  
    for (int i = 0; i < n; i++)
        printf("%d ", arr[i]);
    return 0;
}
