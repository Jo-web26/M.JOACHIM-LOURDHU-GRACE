#include <stdio.h>

int findLen(char* s) {
  	char* last = s;
  
	// Go to the last character
  	while(*last++);
  	
  	// Return difference between last and s
  	return last - s - 1;
}

int main() {
    char s[] = "Geeks";

    // Print the length of string s
    printf("%d", findLen(s));
    return 0;
}
