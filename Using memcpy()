#include <stdio.h>
#include <string.h>

void concat(char *s1, const char *s2) {

    // Copy s2 to the end of s1 using memcpy()
    memcpy(s1 + strlen(s1), s2, strlen(s2) + 1);
}

int main() {
    char s1[50] = "Hello";
    char s2[] = " Geeks";

    // Concatenate using memcpy()
    concat(s1, s2);

    printf("%s", s1);
    return 0;
}
