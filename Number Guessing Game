#include <stdio.h>
#include <stdlib.h>
#include <time.h>
int main() {
    int secret, guess;
    srand(time(0));
    secret = rand() % 100 + 1;
    do {
        printf("Guess (1-100): ");
        scanf("%d", &guess);
        if (guess > secret) printf("Too high!\n");
        else if (guess < secret) printf("Too low!\n");
    } while (guess != secret);
    printf("Correct! The number was %d.", secret);
    return 0;
}
